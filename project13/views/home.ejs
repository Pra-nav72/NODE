<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>home</title>
</head>
<body>
    <h2>hello, user!</h2>
    <button onclick="redirect('login')">login</button><br>
    <button onclick="redirect('signup')">signup</button>

    <script>
    function redirect(target){
        if(target === 'login'){
            window.location.href = '/login';
        } else {
            window.location.href = '/signup';
        }
    }
</script>
</body>
</html>